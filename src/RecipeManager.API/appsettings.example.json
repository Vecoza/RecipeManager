{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=recipemanager;Username=YOUR_USERNAME;Password=YOUR_PASSWORD"
  },
  "JwtSettings": {
    "Secret": "REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS",
    "Issuer": "RecipeManagerAPI",
    "Audience": "RecipeManagerClient",
    "ExpiryInDays": 7
  }
}
